{
  "name": "pear-stamp",
  "version": "1.0.2",
  "main": "index.js",
  "type": "commonjs",
  "description": "Pear template transforms",
  "license": "Apache-2.0",
  "files": [],
  "scripts": {
    "format": "prettier --write .",
    "lint": "prettier --check . && lunte",
    "test:gen": "brittle -r test/all.js test/*.test.js",
    "test": "npm run test:node && npm run test:bare",
    "test:node": "brittle-node test/all.js",
    "test:bare": "brittle-bare test/all.js"
  },
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    }
  },
  "devDependencies": {
    "bare-fs": "^4.2.0",
    "bare-path": "^3.0.0",
    "brittle": "^3.0.0",
    "lunte": "^1.0.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0"
  },
  "dependencies": {
    "streamx": "^2.22.1"
  }
}
